  <link rel="icon" type="image/svg+xml" href='data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64"><defs><radialGradient id="g" cx="35%25" cy="24%25" r="75%25"><stop offset="0%25" stop-color="%23ffffff"/><stop offset="33%25" stop-color="%237dd3fc"/><stop offset="66%25" stop-color="%2322c55e"/><stop offset="100%25" stop-color="%231e3a8a"/></radialGradient></defs><rect width="64" height="64" rx="18" fill="%23071f5f"/><circle cx="32" cy="32" r="23" fill="url(%23g)"/><circle cx="23" cy="21" r="7" fill="%23ffffff" opacity=".78"/><path d="M14 40C25 22 42 19 52 31" fill="none" stroke="%23bbf7d0" stroke-width="4" stroke-linecap="round" opacity=".82"/></svg>' />
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  
  <style>

    @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@400;500;600;700;800&display=swap');
    * { font-family: 'Noto Sans Thai', system-ui, sans-serif; }
    :root { --blue-1:#071f5f; --blue-2:#1d4ed8; --blue-3:#38bdf8; --glow: rgba(56,189,248,.45); }
    html { scroll-behavior: smooth; }
    body { background: radial-gradient(circle at 10% 0%, #e0f2fe 0, transparent 30%), linear-gradient(180deg,#f8fbff,#eef6ff); color: #172554; overflow-x: hidden; }
    body::before { content:""; position: fixed; inset: -20%; z-index: -1; background: radial-gradient(circle at 20% 20%, rgba(59,130,246,.18), transparent 22%), radial-gradient(circle at 85% 10%, rgba(14,165,233,.16), transparent 24%), radial-gradient(circle at 55% 85%, rgba(37,99,235,.13), transparent 28%); animation: auroraMove 18s ease-in-out infinite alternate; }
    .hero { position: relative; background: radial-gradient(circle at 18% 18%, rgba(191,219,254,.72), transparent 24%), radial-gradient(circle at 82% 14%, rgba(125,211,252,.42), transparent 26%), linear-gradient(135deg,#071f5f 0%,#1d4ed8 52%,#38bdf8 100%); }
    .hero::before { content:""; position:absolute; inset:0; background-image: linear-gradient(rgba(255,255,255,.08) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.08) 1px, transparent 1px); background-size: 44px 44px; mask-image: linear-gradient(to bottom, rgba(0,0,0,.8), transparent); }
    .hero::after { content:""; position:absolute; width:560px; height:560px; right:-180px; top:-120px; border-radius:999px; background: radial-gradient(circle, rgba(255,255,255,.28), transparent 62%); filter: blur(2px); animation: floatSlow 9s ease-in-out infinite; }
    .glass { background: linear-gradient(145deg, rgba(39, 70, 93, 0.86), rgba(219,234,254,.68)); backdrop-filter: blur(20px); border:1px solid rgba(255,255,255,.7); box-shadow: 0 30px 90px rgba(15, 23, 42, .18); }
    .card { position: relative; overflow: hidden; transitio
      n: transform .35s cubic-bezier(.2,.8,.2,1), box-shadow .35s ease, border-color .35s ease; animation: fadeUp .7s ease both; }
    .card::before { content:""; position:absolute; inset:0; background: linear-gradient(120deg, transparent 0%, rgba(59,130,246,.08) 42%, rgba(125,211,252,.16) 50%, transparent 62%); transform: translateX(-120%); transition: transform .7s ease; pointer-events:none; }
    .card:hover { transform: translateY(-9px) scale(1.015); box-shadow: 0 30px 80px rgba(37,99,235,.22); border-color: rgba(59,130,246,.38); }
    .card:hover::before { transform: translateX(120%); }
    .nav-active { color: #1342c1; background: linear-gradient(135deg,#dbeafe,#e0f2fe); box-shadow: inset 0 0 0 1px rgba(59,130,246,.18); }
