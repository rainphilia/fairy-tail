<body>
  <header class="sticky top-0 z-40 bg-white/86 backdrop-blur-xl border-b border-blue-100 shadow-[0_10px_40px_rgba(37,99,235,.08)]">
    <div class="max-w-7xl mx-auto px-4 py-3 flex flex-wrap items-center justify-between gap-4">
      <button onclick="showPage('home')" class="flex items-center gap-3">
        <div class="fairy-orb-logo logo-small" aria-label="ไอคอนลูกแก้ว Fairy Tail"><span class="orb-core"><span class="orb-sequoia-ring"></span><span class="orb-shine"></span></span></div>
        <div class="text-left">
