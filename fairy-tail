        <button data-page="tutorRoom" onclick="showPage('tutorRoom')" class="navbtn px-4 py-2 rounded-2xl hover:bg-blue-50">ห้องติวเตอร์</button>
        <a href="#support" class="px-4 py-2 rounded-2xl hover:bg-blue-50 text-blue-700">แจ้งปัญหา</a>
      </nav>
      <div id="guestActions" class="flex gap-2">
        <button onclick="openModal('loginModal')" class="px-4 py-2 rounded-2xl border border-blue-500 text-blue-700 font-semibold">เข้าสู่ระบบ</button>
        <button onclick="openModal('registerModal')" class="px-4 py-2 rounded-2xl bg-blue-600 text-white font-semibold shadow">สมัครสมาชิก</button>
