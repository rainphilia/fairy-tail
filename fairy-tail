        <label class="block"><span class="font-bold">อัปโหลดคลิปวิดีโอในโพสต์ชุมชน</span><input id="postVideo" type="file" accept="video/*" class="mt-2 block w-full text-sm" /></label>
        <button class="w-full py-4 rounded-2xl bg-blue-600 text-white font-extrabold">โพสต์ลงเว็บไซต์</button>
      </form>
    </div>
  </div>

  <div id="chatModal" class="hidden fixed inset-0 z-50 bg-slate-950/70 p-4">
    <div class="modal max-w-2xl mx-auto my-8 bg-white rounded-[2rem] overflow-hidden">
      <div class="p-5 bg-blue-700 text-white flex justify-between items-center">
        <div><h3 id="chatTitle" class="text-xl font-extrabold"></h3><p class="text-sm text-blue-100">แชทส่วนตัวสำหรับตกลงเรียนออนไลน์/ออฟไลน์</p></div>
        <button onclick="closeModal('chatModal')" class="text-3xl">×</button>
      </div>
      <div id="chatBox" class="h-96 overflow-y-auto p-5 bg-blue-50 scrollbar"></div>
      <form onsubmit="sendChat(event)" class="p-4 flex gap-3 border-t border-blue-100">
        <input id="chatInput" class="flex-1 px-4 py-3 rounded-2xl border border-blue-200" placeholder="พิมพ์ข้อความ..." />
        <button class="px-6 rounded-2xl bg-blue-600 text-white font-bold">ส่ง</button>
      </form>
    </div>
  </div>

  <div id="reviewModal" class="hidden fixed inset-0 z-50 bg-slate-950/70 p-4 overflow-y-auto">
    <div class="modal max-w-xl mx-auto my-10 bg-white rounded-[2rem] p-7">
      <div class="flex justify-between gap-4"><div><h3 id="reviewTitle" class="text-3xl font-extrabold text-blue-900">ให้คะแนนติวเตอร์</h3><p id="reviewHint" class="text-blue-600 mt-1"></p></div><button onclick="closeModal('reviewModal')" class="text-3xl text-slate-400">×</button></div>
      <form onsubmit="submitReview(event)" class="mt-6 space-y-4">
        <label class="block font-bold text-blue-900">คะแนน</label>
        <select id="reviewRating" required class="input">
          <option value="">เลือกคะแนน</option>
          <option value="5">5 ดาว — ดีมาก</option>
          <option value="4">4 ดาว — ดี</option>
          <option value="3">3 ดาว — ปานกลาง</option>
          <option value="2">2 ดาว — ควรปรับปรุง</option>
          <option value="1">1 ดาว — ไม่พอใจ</option>
        </select>
        <label class="block font-bold text-blue-900">รีวิว / ความคิดเห็น</label>
        <textarea id="reviewText" required placeholder="เขียนรีวิวอย่างสุภาพ เช่น สอนเข้าใจง่าย ตรงเวลา หรือมีจุดที่อยากให้ปรับปรุง" class="input h-32"></textarea>
        <p class="text-sm text-blue-600">หนึ่งบัญชีสามารถรีวิวติวเตอร์คนเดิมได้หนึ่งครั้ง หากส่งใหม่จะอัปเดตรีวิวเดิมของบัญชีนั้น</p>
        <button class="w-full py-4 rounded-2xl bg-amber-500 text-white font-extrabold">บันทึกรีวิวและคะแนน</button>
      </form>
    </div>
  </div>

  <script>
    const subjects = ['เคมี','ชีวะ','ฟิสิกส์','วิทยาศาสตร์พื้นฐาน','ดาราศาสตร์','คณิตศาสตร์เพิ่มเติม','คณิตศาสตร์พื้นฐาน','สถิติ','แคลคูลัสเบื้องต้น','ภาษาอังกฤษ','ภาษาไทย','ภาษาญี่ปุ่น','ภาษาจีน','สังคมศึกษา','ประวัติศาสตร์','ภูมิศาสตร์','เศรษฐศาสตร์','หน้าที่พลเมือง','ศาสนาและวัฒนธรรม','สังคมการปฏิบัติ','คอมพิวเตอร์','เขียนโปรแกรม Python','เขียนเว็บไซต์ HTML CSS JavaScript','ออกแบบ UI UX','กราฟิกดีไซน์','ตัดต่อวิดีโอ','ดนตรี','ศิลปะ','สุขศึกษา','แนะแนวการเรียน','เตรียมสอบ TGAT TPAT','เตรียมสอบ A-Level'];
    const grades = ['ม.1','ม.2','ม.3','ม.4','ม.5','ม.6'];
    const DEVELOPER_SECRET_CODE = 'kucsow-3kimvi-Heqbarkucsow-3kimvi-Heqbar';
    const $ = id => document.getElementById(id);
    const store = {
      get accounts(){ return JSON.parse(localStorage.getItem('ft_accounts') || '[]'); },
      set accounts(v){ localStorage.setItem('ft_accounts', JSON.stringify(v)); },
      get posts(){ return JSON.parse(localStorage.getItem('ft_posts') || '[]'); },
      set posts(v){ localStorage.setItem('ft_posts', JSON.stringify(v)); },
      get chats(){ return JSON.parse(localStorage.getItem('ft_chats') || '{}'); },
      set chats(v){ localStorage.setItem('ft_chats', JSON.stringify(v)); },
      get reviews(){ return JSON.parse(localStorage.getItem('ft_reviews') || '[]'); },
      set reviews(v){ localStorage.setItem('ft_reviews', JSON.stringify(v)); },
      get current(){ return JSON.parse(localStorage.getItem('ft_current') || 'null'); },
      set current(v){ v ? localStorage.setItem('ft_current', JSON.stringify(v)) : localStorage.removeItem('ft_current'); }
    };
    let selectedLearnGrade = '', activeChatWith = null, activeReviewTutorId = null;

    document.querySelectorAll('.input').forEach(el => el.classList.add('w-full','px-4','py-3','rounded-2xl','border','border-blue-200','focus:outline-none','focus:ring-2','focus:ring-blue-400'));

    function init(){
      fillSelects(); renderGradeButtons(); renderTeachOptions(); cleanLegacyStarterData(); renderAll(); showPage('home');
      document.addEventListener('keydown', e => { if(e.key === 'Escape') document.querySelectorAll('.fixed').forEach(m => m.classList.add('hidden')); });
    }
    function fillSelects(){
      $('regGrade').innerHTML = '<option value="">เลือกระดับชั้น</option>' + grades.map(g=>`<option>${g}</option>`).join('');
      $('learnSubject').innerHTML = '<option value="">เลือกรายวิชา</option>' + subjects.map(s=>`<option>${s}</option>`).join('');
      if($('subjectShowcase')) $('subjectShowcase').innerHTML = subjects.slice(0, 18).map(s => `<span class="subject-chip px-3 py-1.5 rounded-full bg-white/80 border border-blue-100 text-blue-700 font-semibold">${s}</span>`).join('') + `<span class="px-3 py-1.5 rounded-full bg-blue-600 text-white font-bold">+${subjects.length - 18} วิชา</span>`;
    }
    function renderGradeButtons(){
      $('learnGrades').innerHTML = grades.map(g => `<button onclick="selectedLearnGrade='${g}'; renderGradeButtons();" class="py-3 rounded-2xl border font-bold ${selectedLearnGrade===g?'bg-blue-600 text-white border-blue-600':'bg-white border-blue-200 text-blue-700'}">${g}</button>`).join('');
    }
    function renderTeachOptions(){
      $('teachGrades').innerHTML = grades.map(g => `<label class="p-3 rounded-2xl border border-blue-100 bg-blue-50"><input type="checkbox" name="teachGrade" value="${g}" class="accent-blue-600"> ${g}</label>`).join('');
      $('teachSubjects').innerHTML = subjects.map(s => `<label class="subject-chip p-3 rounded-2xl border border-blue-100 bg-blue-50"><input type="checkbox" name="teachSubject" value="${s}" class="accent-blue-600"> ${s}</label>`).join('');
    }
    function showPage(id){
      document.querySelectorAll('.page').forEach(p => p.classList.add('hidden'));
      $(id).classList.remove('hidden');
      document.querySelectorAll('.navbtn').forEach(b => b.classList.toggle('nav-active', b.dataset.page === id));
      if(id === 'community') renderPosts();
      if(id === 'matching') { renderGradeButtons(); matchTutors(true); }
      if(id === 'tutorRoom') renderTutorRoom();
      if(id === 'developer') renderDeveloper();
      window.scrollTo({top:0, behavior:'smooth'});
    }
    function openModal(id){ $(id).classList.remove('hidden'); if(id === 'registerModal') toggleDeveloperSecret(); }
    function closeModal(id){ $(id).classList.add('hidden'); }
    function toggleDeveloperSecret(){
      const isDeveloperRole = $('regRole')?.value === 'developer';
      if($('regDevSecretWrap')) $('regDevSecretWrap').classList.toggle('hidden', !isDeveloperRole);
      if($('regDevSecret')) $('regDevSecret').required = isDeveloperRole;
    }
    function avatar(seed){ return `https://api.dicebear.com/8.x/adventurer/svg?seed=${encodeURIComponent(seed || 'fairy')}`; }
    function nowThai(){ return new Date().toLocaleString('th-TH', { dateStyle:'medium', timeStyle:'short' }); }
    function escapeHtml(value){ return String(value ?? '').replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',"'":'&#39;'}[ch])); }
    function currentAccount(){ const cur = store.current; return cur ? store.accounts.find(a => a.id === cur.id) : null; }
    function isBanned(a){ return a?.banUntil && new Date(a.banUntil) > new Date(); }
    function roleText(r){ return r === 'tutor' ? 'ติวเตอร์' : r === 'developer' ? 'ผู้พัฒนา' : 'ผู้เรียน'; }

    function register(e){
      e.preventDefault();
      const accounts = store.accounts;
      const realKey = `${$('regFirst').value.trim()}|${$('regLast').value.trim()}|${$('regGrade').value}`.toLowerCase();
      if(accounts.some(a => a.realKey === realKey)) return alert('มีชื่อจริง นามสกุลจริง และระดับชั้นนี้ในระบบแล้ว ไม่สามารถสมัครซ้ำได้');
      if(accounts.some(a => a.email === $('regEmail').value.trim())) return alert('อีเมลนี้ถูกใช้แล้ว');
      const selectedRole = $('regRole').value;
      if(selectedRole === 'developer' && $('regDevSecret').value.trim() !== DEVELOPER_SECRET_CODE) return alert('รหัสลับผู้พัฒนาไม่ถูกต้อง ไม่สามารถสมัครบทบาทผู้พัฒนาได้');
      const a = { id: Date.now(), realKey, first:$('regFirst').value.trim(), last:$('regLast').value.trim(), grade:$('regGrade').value, email:$('regEmail').value.trim(), pass:$('regPass').value, role:selectedRole, nick:$('regNick').value.trim(), bio:$('regBio').value.trim(), avatar:$('regAvatar').value.trim() || avatar($('regNick').value), createdAt: nowThai(), tutor:{open:false, grades:[], subjects:[], mode:'ออนไลน์'}, contacts:0, banUntil:null };
      accounts.push(a); store.accounts = accounts; store.current = {id:a.id}; closeModal('registerModal'); renderAll(); alert('สมัครสมาชิกสำเร็จ');
    }
    function login(e){
      e.preventDefault();
      const a = store.accounts.find(x => x.email === $('loginEmail').value.trim() && x.pass === $('loginPass').value);
      if(!a) return alert('อีเมลหรือรหัสผ่านไม่ถูกต้อง');
      if(isBanned(a)) return alert('บัญชีนี้ถูกแบนถึงวันที่ ' + new Date(a.banUntil).toLocaleDateString('th-TH'));
      store.current = {id:a.id}; closeModal('loginModal'); renderAll(); alert('เข้าสู่ระบบสำเร็จ');
    }
    function logout(){ store.current = null; $('devPanel').classList.add('hidden'); $('devLocked').classList.remove('hidden'); renderAll(); alert('ออกจากระบบแล้ว'); }
    function renderAuth(){
      const a = currentAccount();
      $('guestActions').classList.toggle('hidden', !!a); $('userActions').classList.toggle('hidden', !a); $('userActions').classList.toggle('flex', !!a);
      if(a){ $('topAvatar').src = a.avatar; $('topName').textContent = a.nick; $('topRole').textContent = roleText(a.role); }
    }
    function openProfile(){
      const a = currentAccount(); if(!a) return;
      $('profileContent').innerHTML = `<div class="text-center"><img src="${a.avatar}" class="w-28 h-28 mx-auto rounded-3xl object-cover bg-blue-50"><h4 class="text-2xl font-extrabold mt-4">${a.nick}</h4><p class="text-blue-600">${roleText(a.role)}</p></div><div class="mt-6 space-y-3 text-blue-900"><p><b>ชื่อจริง:</b> ${a.first} ${a.last}</p><p><b>ระดับชั้น:</b> ${a.grade}</p><p><b>อีเมล:</b> ${a.email}</p><p><b>แนะนำตัว:</b> ${a.bio || '-'}</p></div>`;
      openModal('profileModal');
    }

    function openCreatePost(){ if(!currentAccount()) return alert('กรุณาเข้าสู่ระบบก่อนโพสต์'); openModal('postModal'); }
    function createPost(e){
      e.preventDefault(); const a = currentAccount(); if(!a) return;
      const file = $('postVideo').files[0];
      const posts = store.posts;
      posts.unshift({ id:Date.now(), authorId:a.id, author:a.nick, avatar:a.avatar, text:$('postText').value.trim(), promote:$('postPromote').checked, videoName:file?file.name:'', videoUrl:file?URL.createObjectURL(file):'', likes:0, time:nowThai() });
      store.posts = posts.map(p => ({...p, videoUrl: p.videoUrl && p.videoUrl.startsWith('blob:') ? '' : p.videoUrl}));
      closeModal('postModal'); $('postText').value=''; $('postPromote').checked=false; $('postVideo').value=''; renderPosts(); alert('โพสต์สำเร็จ');
    }
    function renderPosts(){
      const posts = store.posts;
      $('postList').innerHTML = posts.length ? posts.map(p => `<article class="card bg-white/95 backdrop-blur rounded-[2rem] border ${p.promote?'border-amber-300 ring-4 ring-amber-50':'border-blue-100'} p-6 shadow-sm">${p.promote?'<span class="inline-block px-3 py-1 rounded-full bg-amber-100 text-amber-700 text-xs font-bold mb-3">โพสต์โปรโมท</span>':''}<div class="flex gap-3 items-center"><img src="${p.avatar}" class="w-12 h-12 rounded-2xl object-cover"><div><h4 class="font-extrabold">${p.author}</h4><p class="text-xs text-blue-500">${p.time}</p></div></div><p class="mt-5 text-blue-900 whitespace-pre-line">${p.text}</p>${p.videoName?`<div class="mt-4 p-4 rounded-2xl bg-blue-50 text-blue-700"><i class="fa-solid fa-video mr-2"></i> แนบคลิป: ${p.videoName}</div>`:''}<div class="mt-5 flex gap-5 text-blue-500"><button onclick="likePost(${p.id})" class="hover:text-red-500"><i class="fa-solid fa-heart"></i> ${p.likes}</button><button><i class="fa-solid fa-comment"></i> คอมเมนต์</button></div></article>`).join('') : '<p class="text-blue-600">ยังไม่มีโพสต์</p>';
    }
    function likePost(id){ const posts = store.posts.map(p => p.id===id ? {...p, likes:p.likes+1} : p); store.posts = posts; renderPosts(); }

    function renderTutorRoom(){
      const a = currentAccount();
      if(!a) { $('tutorStatusCard').innerHTML = '<p class="text-blue-700">กรุณาเข้าสู่ระบบก่อนตั้งค่าติวเตอร์</p>'; return; }
      if(a.role !== 'tutor') { $('tutorStatusCard').innerHTML = '<p class="text-red-600 font-bold">บัญชีนี้ไม่ใช่บทบาทติวเตอร์ กรุณาสมัครหรือเข้าสู่ระบบด้วยบัญชีติวเตอร์</p>'; return; }
      $('tutorOpen').checked = !!a.tutor.open; document.querySelectorAll('[name=teachGrade]').forEach(c => c.checked = a.tutor.grades.includes(c.value)); document.querySelectorAll('[name=teachSubject]').forEach(c => c.checked = a.tutor.subjects.includes(c.value)); $('teachMode').value = a.tutor.mode || 'ออนไลน์'; renderTutorStatus(a);
    }
    function saveTutorSettings(e){
      e.preventDefault(); const a = currentAccount(); if(!a || a.role !== 'tutor') return alert('ต้องเป็นบัญชีติวเตอร์ก่อน');
      const accounts = store.accounts; const i = accounts.findIndex(x => x.id === a.id);
      accounts[i].tutor = { open:$('tutorOpen').checked, grades:[...document.querySelectorAll('[name=teachGrade]:checked')].map(x=>x.value), subjects:[...document.querySelectorAll('[name=teachSubject]:checked')].map(x=>x.value), mode:$('teachMode').value };
      store.accounts = accounts; renderTutorStatus(accounts[i]); renderDeveloper(); alert('บันทึกข้อมูลการสอนแล้ว');
    }
    function renderTutorStatus(a){
      const summary = tutorRatingSummary(a.id);
      const latest = tutorReviews(a.id).slice(0, 3);
      $('tutorStatusCard').innerHTML = `<div class="p-5 rounded-3xl bg-white border border-blue-100"><p class="text-sm text-blue-500">สถานะ</p><p class="text-2xl font-extrabold ${a.tutor.open?'text-emerald-600':'text-slate-500'}">${a.tutor.open?'เปิดสอน':'ปิดสอน'}</p><hr class="my-4"><p><b>ระดับชั้น:</b> ${a.tutor.grades.join(', ') || '-'}</p><p class="mt-2"><b>รายวิชา:</b> ${a.tutor.subjects.join(', ') || '-'}</p><p class="mt-2"><b>รูปแบบ:</b> ${a.tutor.mode || '-'}</p><div class="mt-4 p-4 rounded-2xl bg-amber-50 border border-amber-100"><p class="font-extrabold text-amber-700">${ratingStars(summary.avg)} ${summary.avg ? summary.avg.toFixed(1) : 'ยังไม่มีคะแนน'} / 5</p><p class="text-sm text-amber-700">จาก ${summary.count} รีวิว</p></div>${latest.length?`<div class="mt-4 space-y-2"><h4 class="font-extrabold text-blue-900">รีวิวล่าสุด</h4>${latest.map(r=>`<div class="p-3 rounded-2xl bg-blue-50 border border-blue-100"><p class="font-bold text-blue-900">${ratingStars(r.rating)} ${r.rating}/5 โดย ${escapeHtml(r.reviewer)}</p><p class="text-sm text-blue-800 mt-1">${escapeHtml(r.text)}</p></div>`).join('')}</div>`:''}</div>`;
    }

    function tutorReviews(tutorId){ return store.reviews.filter(r => r.tutorId === tutorId).sort((a,b)=>b.id-a.id); }
    function tutorRatingSummary(tutorId){ const reviews = tutorReviews(tutorId); const count = reviews.length; const avg = count ? reviews.reduce((sum,r)=>sum+Number(r.rating || 0),0)/count : 0; return {avg, count}; }
    function ratingStars(value){ const rounded = Math.round(Number(value || 0)); return '★★★★★'.split('').map((s,i)=>`<span class="${i<rounded?'text-amber-400':'text-slate-300'}">★</span>`).join(''); }
    function openReviewModal(tutorId){
      const me = currentAccount();
      if(!me) return alert('กรุณาเข้าสู่ระบบก่อนให้คะแนนติวเตอร์');
      if(isBanned(me)) return alert('บัญชีนี้ถูกแบน ไม่สามารถให้คะแนนได้');
      if(me.id === tutorId) return alert('ไม่สามารถรีวิวบัญชีติวเตอร์ของตัวเองได้');
      const tutor = store.accounts.find(a => a.id === tutorId && a.role === 'tutor');
      if(!tutor) return alert('ไม่พบติวเตอร์นี้ในระบบ');
      activeReviewTutorId = tutorId;
      $('reviewTitle').textContent = 'ให้คะแนน ' + tutor.nick;
      $('reviewHint').textContent = 'รีวิวนี้จะแสดงในหน้าจับคู่ติวเตอร์และแดชบอร์ดผู้พัฒนา';
      const old = store.reviews.find(r => r.tutorId === tutorId && r.reviewerId === me.id);
      $('reviewRating').value = old ? String(old.rating) : '';
      $('reviewText').value = old ? old.text : '';
      openModal('reviewModal');
    }
    function submitReview(e){
      e.preventDefault();
      const me = currentAccount();
      if(!me || !activeReviewTutorId) return alert('กรุณาเลือกติวเตอร์ก่อนให้คะแนน');
      const rating = Number($('reviewRating').value);
      const text = $('reviewText').value.trim();
      if(!rating || rating < 1 || rating > 5 || !text) return alert('กรุณาเลือกคะแนน 1-5 และเขียนรีวิว');
      const reviews = store.reviews;
      const existing = reviews.findIndex(r => r.tutorId === activeReviewTutorId && r.reviewerId === me.id);
      const review = { id: existing >= 0 ? reviews[existing].id : Date.now(), tutorId: activeReviewTutorId, reviewerId: me.id, reviewer: me.nick, rating, text, time: nowThai() };
      if(existing >= 0) reviews[existing] = review; else reviews.unshift(review);
      store.reviews = reviews;
      closeModal('reviewModal'); $('reviewRating').value=''; $('reviewText').value=''; activeReviewTutorId = null;
      matchTutors(true); renderTutorRoom(); renderDeveloper(); alert('บันทึกรีวิวและคะแนนเรียบร้อย');
    }

    function matchTutors(silent=false){
      const subject = $('learnSubject').value; if((!selectedLearnGrade || !subject) && !silent) return alert('กรุณาเลือกระดับชั้นและรายวิชา');
      const tutors = store.accounts.filter(a => a.role==='tutor' && a.tutor.open && !isBanned(a) && (!selectedLearnGrade || a.tutor.grades.includes(selectedLearnGrade)) && (!subject || a.tutor.subjects.includes(subject)));
      $('matchResults').innerHTML = tutors.length ? tutors.map(t => {
        const summary = tutorRatingSummary(t.id);
        const latest = tutorReviews(t.id).slice(0, 2);
        return `<article class="card bg-white/95 backdrop-blur rounded-[2rem] p-6 border border-blue-100 shadow-sm"><div class="flex gap-4"><img src="${t.avatar}" class="w-16 h-16 rounded-2xl object-cover"><div><h4 class="text-xl font-extrabold">${t.nick}</h4><p class="text-blue-600">${escapeHtml(t.bio || 'ติวเตอร์ Fairy Tail')}</p><div class="mt-2 text-sm font-bold">${ratingStars(summary.avg)} <span class="text-amber-600">${summary.avg ? summary.avg.toFixed(1) : 'ยังไม่มีคะแนน'}</span> <span class="text-blue-500">(${summary.count} รีวิว)</span></div></div></div><div class="mt-5 flex flex-wrap gap-2">${t.tutor.grades.map(g=>`<span class="px-3 py-1 rounded-full bg-blue-50 text-blue-700 text-sm">${g}</span>`).join('')}${t.tutor.subjects.map(s=>`<span class="px-3 py-1 rounded-full bg-sky-50 text-sky-700 text-sm">${s}</span>`).join('')}</div><p class="mt-4"><b>รูปแบบ:</b> ${t.tutor.mode}</p>${latest.length?`<div class="mt-4 space-y-2"><h5 class="font-extrabold text-blue-900">รีวิวล่าสุด</h5>${latest.map(r=>`<div class="p-3 rounded-2xl bg-blue-50 border border-blue-100"><p class="font-bold text-blue-900">${ratingStars(r.rating)} ${r.rating}/5 โดย ${escapeHtml(r.reviewer)}</p><p class="text-sm text-blue-800 mt-1">${escapeHtml(r.text)}</p></div>`).join('')}</div>`:''}<div class="mt-5 grid sm:grid-cols-2 gap-3"><button onclick="startChat(${t.id})" class="py-3 rounded-2xl bg-blue-600 text-white font-bold">แชทเพื่อตกลงการสอน</button><button onclick="openReviewModal(${t.id})" class="py-3 rounded-2xl bg-amber-500 text-white font-bold">ให้คะแนน/รีวิว</button></div></article>`;
      }).join('') : '<div class="p-8 rounded-[2rem] bg-white border border-blue-100 text-blue-700">ยังไม่พบติวเตอร์ที่ตรงเงื่อนไข ลองเปลี่ยนวิชาหรือระดับชั้น</div>';
    }
    function startChat(tutorId){
      const me = currentAccount(); if(!me) return alert('กรุณาเข้าสู่ระบบก่อนเริ่มแชท');
      activeChatWith = tutorId; const t = store.accounts.find(a=>a.id===tutorId); $('chatTitle').textContent = 'แชทกับ ' + t.nick;
      const accounts = store.accounts; const i = accounts.findIndex(a=>a.id===tutorId); if(i>=0){ accounts[i].contacts = (accounts[i].contacts||0)+1; store.accounts = accounts; }
      renderChat(); openModal('chatModal');
    }
    function chatKey(){ const me = currentAccount(); return [me.id, activeChatWith].sort().join('_'); }
    function renderChat(){
      const me = currentAccount(); const chats = store.chats; const list = chats[chatKey()] || [];
      $('chatBox').innerHTML = list.length ? list.map(m => `<div class="mb-3 flex ${m.from===me.id?'justify-end':'justify-start'}"><div class="max-w-[75%] px-4 py-3 rounded-3xl ${m.from===me.id?'bg-blue-600 text-white rounded-tr-none':'bg-white text-blue-900 rounded-tl-none'}"><p>${m.text}</p><p class="text-[10px] opacity-70 mt-1">${m.time}</p></div></div>`).join('') : '<p class="text-blue-600 text-center mt-20">ยังไม่มีข้อความ เริ่มคุยเพื่อตกลงเรียนได้เลย</p>';
      $('chatBox').scrollTop = $('chatBox').scrollHeight;
    }
    function sendChat(e){
      e.preventDefault(); const me = currentAccount(); const text = $('chatInput').value.trim(); if(!text) return;
      const chats = store.chats; const key = chatKey(); chats[key] = chats[key] || []; chats[key].push({from:me.id, text, time:nowThai()}); store.chats = chats; $('chatInput').value=''; renderChat();
    }

    function developerLogin(){
      const a = currentAccount();
      if(!a){ alert('กรุณาเข้าสู่ระบบด้วยบัญชีผู้พัฒนาก่อน'); openModal('loginModal'); return; }
      if(isBanned(a)) return alert('บัญชีนี้ถูกแบนถึงวันที่ ' + new Date(a.banUntil).toLocaleDateString('th-TH'));
      if(a.role !== 'developer') return alert('บัญชีนี้ไม่ใช่บทบาทผู้พัฒนา กรุณาเข้าสู่ระบบด้วยบัญชีผู้พัฒนา');
      if($('devAccessCode') && $('devAccessCode').value.trim() !== DEVELOPER_SECRET_CODE) return alert('รหัสลับผู้พัฒนาไม่ถูกต้อง');
      if($('devAccessCode')) $('devAccessCode').value = '';
      $('devLocked').classList.add('hidden'); $('devPanel').classList.remove('hidden'); renderDeveloper();
    }
    function renderDeveloper(){
      const dev = currentAccount();
      const allowed = dev && dev.role === 'developer' && !isBanned(dev);
      if(!allowed){
        $('devPanel').classList.add('hidden'); $('devLocked').classList.remove('hidden');
        if($('devAccountHint')){
          $('devAccountHint').innerHTML = dev ? `กำลังใช้บัญชี <b>${dev.nick}</b> (${roleText(dev.role)}) ซึ่งยังไม่มีสิทธิ์ผู้พัฒนา` : 'กรุณาเข้าสู่ระบบด้วยบัญชีผู้พัฒนาก่อนเข้าแดชบอร์ด';
        }
        return;
      }
      $('devLocked').classList.add('hidden'); $('devPanel').classList.remove('hidden');
      const accounts = store.accounts, posts = store.posts, reviews = store.reviews, tutors = accounts.filter(a=>a.role==='tutor'), openTutors = tutors.filter(a=>a.tutor.open), chats = Object.values(store.chats).reduce((sum,arr)=>sum+arr.length,0);
      const cards = [['บัญชีทั้งหมด',accounts.length,'fa-users'],['ติวเตอร์เปิดสอน',openTutors.length,'fa-chalkboard-user'],['โพสต์ทั้งหมด',posts.length,'fa-newspaper'],['รีวิวทั้งหมด',reviews.length,'fa-star'],['ข้อความแชทรวม',chats,'fa-comments'],['บัญชีถูกแบน',accounts.filter(isBanned).length,'fa-ban']];
      $('insights').innerHTML = cards.map(c => `<div class="bg-white rounded-3xl p-5 border border-blue-100 shadow-sm"><i class="fa-solid ${c[2]} text-blue-600 text-2xl"></i><p class="text-sm text-blue-500 mt-3">${c[0]}</p><p class="text-3xl font-extrabold text-blue-900">${c[1]}</p></div>`).join('');
      $('accountTable').innerHTML = accounts.length ? accounts.map(a => `<tr class="border-t border-blue-50"><td class="p-4">${a.first} ${a.last}</td><td class="p-4"><div class="flex items-center gap-2"><img src="${a.avatar}" class="w-9 h-9 rounded-xl">${a.nick}</div></td><td class="p-4">${roleText(a.role)}</td><td class="p-4">${a.grade}</td><td class="p-4">${isBanned(a)?'<span class="text-red-600 font-bold">แบนอยู่</span>':'<span class="text-emerald-600 font-bold">ปกติ</span>'}</td><td class="p-4"><button onclick="banAccount(${a.id})" class="px-3 py-2 rounded-xl bg-red-50 text-red-600 font-bold">แบน 1-30 วัน</button> <button onclick="unbanAccount(${a.id})" class="px-3 py-2 rounded-xl bg-blue-50 text-blue-600 font-bold">ปลดแบน</button></td></tr>`).join('') : '<tr><td class="p-4 text-blue-600" colspan="6">ยังไม่มีบัญชี</td></tr>';
      if($('postTable')) $('postTable').innerHTML = posts.length ? posts.map(p => `<tr class="border-t border-blue-50"><td class="p-4"><div class="flex items-center gap-2"><img src="${p.avatar}" class="w-9 h-9 rounded-xl">${p.author}</div></td><td class="p-4 max-w-md"><div class="line-clamp-3 whitespace-pre-line text-blue-950">${p.text}</div>${p.videoName?`<div class="mt-2 text-xs text-blue-600"><i class="fa-solid fa-video mr-1"></i>${p.videoName}</div>`:''}</td><td class="p-4 text-blue-700">${p.time}</td><td class="p-4">${p.promote?'<span class="text-amber-600 font-bold">โปรโมท</span>':'<span class="text-slate-500">ทั่วไป</span>'}</td><td class="p-4"><button onclick="deletePostByDeveloper(${p.id})" class="px-3 py-2 rounded-xl bg-red-50 text-red-600 font-bold">ลบโพสต์</button></td></tr>`).join('') : '<tr><td class="p-4 text-blue-600" colspan="5">ยังไม่มีโพสต์</td></tr>';
      if($('reviewTable')) $('reviewTable').innerHTML = reviews.length ? reviews.map(r => { const tutor = accounts.find(a=>a.id===r.tutorId); return `<tr class="border-t border-blue-50"><td class="p-4">${tutor ? `<div class="flex items-center gap-2"><img src="${tutor.avatar}" class="w-9 h-9 rounded-xl">${tutor.nick}</div>` : '<span class="text-slate-500">ไม่พบบัญชีติวเตอร์</span>'}</td><td class="p-4">${escapeHtml(r.reviewer)}</td><td class="p-4"><span class="font-bold text-amber-600">${ratingStars(r.rating)} ${r.rating}/5</span></td><td class="p-4 max-w-md whitespace-pre-line text-blue-950">${escapeHtml(r.text)}</td><td class="p-4 text-blue-700">${r.time}</td><td class="p-4"><button onclick="deleteReviewByDeveloper(${r.id})" class="px-3 py-2 rounded-xl bg-red-50 text-red-600 font-bold">ลบรีวิว</button></td></tr>`; }).join('') : '<tr><td class="p-4 text-blue-600" colspan="6">ยังไม่มีรีวิว</td></tr>';
    }
    function banAccount(id){ const days = Number(prompt('ต้องการแบนกี่วัน? ใส่ 1-30')); if(!days || days<1 || days>30) return alert('กรุณาใส่จำนวน 1-30 วัน'); const accounts = store.accounts; const i = accounts.findIndex(a=>a.id===id); accounts[i].banUntil = new Date(Date.now()+days*86400000).toISOString(); store.accounts = accounts; renderDeveloper(); alert('แบนบัญชีเรียบร้อย'); }
    function unbanAccount(id){ const accounts = store.accounts; const i = accounts.findIndex(a=>a.id===id); accounts[i].banUntil = null; store.accounts = accounts; renderDeveloper(); }
    function deletePostByDeveloper(id){ const dev = currentAccount(); if(!dev || dev.role !== 'developer' || isBanned(dev)) return alert('ต้องเข้าสู่ระบบด้วยบัญชีผู้พัฒนาก่อน'); if(!confirm('ต้องการลบโพสต์นี้ออกจากชุมชนใช่ไหม?')) return; store.posts = store.posts.filter(p => p.id !== id); renderPosts(); renderDeveloper(); alert('ลบโพสต์เรียบร้อย'); }
    function deleteReviewByDeveloper(id){ const dev = currentAccount(); if(!dev || dev.role !== 'developer' || isBanned(dev)) return alert('ต้องเข้าสู่ระบบด้วยบัญชีผู้พัฒนาก่อน'); if(!confirm('ต้องการลบรีวิวนี้ออกจากระบบใช่ไหม?')) return; store.reviews = store.reviews.filter(r => r.id !== id); matchTutors(true); renderTutorRoom(); renderDeveloper(); alert('ลบรีวิวเรียบร้อย'); }

    function cleanLegacyStarterData(){
      // ล้างข้อมูลเริ่มต้นจากเวอร์ชันก่อนหน้าโดยอ้างอิงเลขระบบภายในเท่านั้น เพื่อไม่ให้มีรายชื่อทดสอบอยู่ในไฟล์
      const legacyAccountIds = new Set([101, 102, 103]);
      const legacyPostIds = new Set([201, 202]);
      const beforeAccounts = store.accounts;
      const filteredAccounts = beforeAccounts.filter(a => !legacyAccountIds.has(a.id));
      if(filteredAccounts.length !== beforeAccounts.length) store.accounts = filteredAccounts;

      const beforePosts = store.posts;
      const filteredPosts = beforePosts.filter(p => !legacyAccountIds.has(p.authorId) && !legacyPostIds.has(p.id));
      if(filteredPosts.length !== beforePosts.length) store.posts = filteredPosts;

      const current = store.current;
      if(current && legacyAccountIds.has(current.id)) store.current = null;
    }
    function renderAll(){ renderAuth(); renderPosts(); renderTutorRoom(); renderDeveloper(); }
    init();
    
  </script>
</body>
</html>
