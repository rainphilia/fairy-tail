    .page:not(.hidden) { animation: pageIn .45s ease both; }
    .reveal { animation: fadeUp .85s ease both; }
    .reveal-delay-1 { animation-delay: .12s; }
    .reveal-delay-2 { animation-delay: .24s; }
    .floating-orb { position:absolute; border-radius:999px; filter: blur(.2px); background: rgba(255,255,255,.18); border:1px solid rgba(255,255,255,.28); box-shadow: 0 0 50px rgba(186,230,253,.28); animation: floatSlow 7s ease-in-out infinite; }
    .floating-star { position:absolute; color:rgba(255,255,255,.75); animation: twinkle 2.4s ease-in-out infinite; }
    .glow-title { text-shadow: 0 0 18px rgba(186,230,253,.62), 0 16px 42px rgba(15,23,42,.2); }
    .shine-btn { position: relative; overflow: hidden; transition: transform .25s ease, box-shadow .25s ease; }
    .shine-btn:hover { transform: translateY(-3px); box-shadow: 0 18px 42px rgba(37,99,235,.28); }
    .shine-btn::after { content:""; position:absolute; inset:-80% auto -80% -45%; width:38%; transform: rotate(18deg); background: linear-gradient(90deg, transparent, rgba(255,255,255,.55), transparent); animation: shine 3.8s ease-in-out infinite; }
    .subject-chip { transition: .25s ease; }
    .subject-chip:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(37,99,235,.16); }
    @keyframes pop { from { transform: scale(.96); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    @keyframes pageIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes floatSlow { 0%,100% { transform: translate3d(0,0,0) scale(1); } 50% { transform: translate3d(18px,-24px,0) scale(1.04); } }
    @keyframes twinkle { 0%,100% { opacity:.35; transform: scale(.9) rotate(0); } 50% { opacity:1; transform: scale(1.16) rotate(12deg); } }
    @keyframes shine { 0%,55% { left:-55%; } 100% { left:130%; } }
    @keyframes auroraMove { from { transform: translate3d(-2%, -1%, 0) rotate(0deg); } to { transform: translate3d(2%, 1%, 0) rotate(3deg); } }

    .fairy-orb-logo { --orb-size: 3rem; width: var(--orb-size); height: var(--orb-size); position: relative; display: grid; place-items: center; border-radius: 1.15rem; isolation: isolate; overflow: visible; background: linear-gradient(145deg, rgba(219,234,254,.94), rgba(14,165,233,.42)); box-shadow: 0 16px 38px rgba(37,99,235,.28), 0 0 0 1px rgba(255,255,255,.9) inset; animation: orbFloat 4.4s ease-in-out infinite; }
    .fairy-orb-logo::before { content:""; position:absolute; inset:-6px; border-radius:1.35rem; background: conic-gradient(from 0deg, rgba(56,189,248,.0), rgba(125,211,252,.9), rgba(34,197,94,.68), rgba(99,102,241,.82), rgba(56,189,248,.0)); filter: blur(.2px); z-index:-2; animation: orbAuraSpin 5.6s linear infinite; }
    .fairy-orb-logo::after { content:""; position:absolute; inset:-12px; border-radius:999px; background: radial-gradient(circle, rgba(186,230,253,.45), transparent 56%); z-index:-3; animation: orbGlowPulse 2.8s ease-in-out infinite; }
    .fairy-orb-logo .orb-core { width:72%; height:72%; position:relative; display:block; border-radius:999px; overflow:hidden; background: radial-gradient(circle at 30% 22%, rgba(255,255,255,.98) 0 10%, rgba(224,242,254,.92) 17%, rgba(56,189,248,.95) 40%, rgba(20,184,166,.93) 62%, rgba(30,64,175,.96) 100%); box-shadow: inset -9px -11px 18px rgba(15,23,42,.28), inset 7px 7px 16px rgba(255,255,255,.72), 0 0 22px rgba(125,211,252,.88); animation: orbCoreBreathe 3.1s ease-in-out infinite; }
    .fairy-orb-logo .orb-core::before { content:""; position:absolute; width:62%; height:28%; left:10%; top:12%; border-radius:999px; background:linear-gradient(90deg, rgba(255,255,255,.8), rgba(255,255,255,.08)); transform:rotate(-25deg); filter: blur(.5px); }
    .fairy-orb-logo .orb-core::after { content:""; position:absolute; width:120%; height:120%; left:-30%; top:-10%; background: conic-gradient(from 150deg, transparent 0 18%, rgba(255,255,255,.34) 20% 24%, transparent 28% 52%, rgba(187,247,208,.38) 56% 61%, transparent 66% 100%); animation: orbInnerSpin 7.5s linear infinite; }
    .fairy-orb-logo .orb-sequoia-ring { position:absolute; inset:18%; border-radius:999px; border:2px solid rgba(187,247,208,.78); border-left-color: rgba(255,255,255,.18); border-bottom-color: rgba(125,211,252,.38); transform:rotate(-18deg) scaleX(1.18); box-shadow:0 0 14px rgba(187,247,208,.46); animation: orbRingTilt 3.8s ease-in-out infinite; }
    .fairy-orb-logo .orb-shine { position:absolute; width:18%; height:18%; right:18%; bottom:20%; border-radius:999px; background:rgba(255,255,255,.82); box-shadow:0 0 16px rgba(255,255,255,.86); animation: orbSpark 1.9s ease-in-out infinite; }
    .fairy-orb-logo.logo-small { --orb-size: 3rem; }
    .fairy-orb-logo.logo-footer { --orb-size: 3rem; border-radius:1.1rem; }
    @keyframes orbFloat { 0%,100% { transform: translateY(0) rotate(-2deg); } 50% { transform: translateY(-5px) rotate(2deg); } }
    @keyframes orbAuraSpin { to { transform: rotate(360deg); } }
    @keyframes orbGlowPulse { 0%,100% { opacity:.55; transform:scale(.94); } 50% { opacity:1; transform:scale(1.16); } }
    @keyframes orbCoreBreathe { 0%,100% { transform:scale(.98); filter:saturate(1); } 50% { transform:scale(1.04); filter:saturate(1.25) brightness(1.05); } }
    @keyframes orbInnerSpin { to { transform: rotate(360deg); } }
    @keyframes orbRingTilt { 0%,100% { transform:rotate(-18deg) scaleX(1.18); opacity:.7; } 50% { transform:rotate(16deg) scaleX(1.05); opacity:1; } }
    @keyframes orbSpark { 0%,100% { transform:scale(.75); opacity:.55; } 50% { transform:scale(1.25); opacity:1; } }
    .scrollbar::-webkit-scrollbar { width: 8px; }
    .scrollbar::-webkit-scrollbar-thumb { background: #93c5fd; border-radius: 999px; }
  </style>
  
